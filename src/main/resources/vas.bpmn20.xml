            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_finance_gwFinance" bpmnElement="flow_finance_gwFinance">
                <omgdi:waypoint x="910.0" y="135.0"/>
                <omgdi:waypoint x="945.0" y="135.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_gwFinance_join" bpmnElement="flow_gwFinance_join">
                <omgdi:waypoint x="995.0" y="135.0"/>
                <omgdi:waypoint x="1120.0" y="135.0"/>
                <omgdi:waypoint x="1120.0" y="220.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_gwFinance_terminate" bpmnElement="flow_gwFinance_terminate">
                <omgdi:waypoint x="970.0" y="160.0"/>
                <omgdi:waypoint x="970.0" y="430.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_aro_gwAro" bpmnElement="flow_aro_gwAro">
                <omgdi:waypoint x="910.0" y="355.0"/>
                <omgdi:waypoint x="945.0" y="355.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_gwAro_join" bpmnElement="flow_gwAro_join">
                <omgdi:waypoint x="995.0" y="355.0"/>
                <omgdi:waypoint x="1120.0" y="355.0"/>
                <omgdi:waypoint x="1120.0" y="270.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_gwAro_terminate" bpmnElement="flow_gwAro_terminate">
                <omgdi:waypoint x="970.0" y="380.0"/>
                <omgdi:waypoint x="970.0" y="430.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_join_notify" bpmnElement="flow_join_notify">
                <omgdi:waypoint x="1145.0" y="245.0"/>
                <omgdi:waypoint x="1185.0" y="245.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_notify_approved" bpmnElement="flow_notify_approved">
                <omgdi:waypoint x="1315.0" y="245.0"/>
                <omgdi:waypoint x="1365.0" y="245.0"/>
            </bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</definitions>
